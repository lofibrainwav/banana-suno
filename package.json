{
  "name": "jadaking-actor",
  "version": "2.0.0",
  "description": "Optimized Apify Actor with enhanced performance, memory optimization, and error handling",
  "main": "main.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "start": "node --expose-gc --max-old-space-size=512 main.js",
    "start:enhanced": "NODE_ENV=development node main.js",
    "start:refactored": "node main-refactored.js",
    "dev": "NODE_ENV=development node --expose-gc --max-old-space-size=512 main.js",
    "prod": "NODE_ENV=production node --expose-gc --max-old-space-size=256 main.js",
    "lint": "echo 'Linting not configured yet'",
    "validate": "node -c main.js && node -c main-refactored.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "apify": "^3.4.3"
  },
  "devDependencies": {
    "dotenv": "^17.2.1",
    "jest": "^29.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js"
    ]
  },
  "directories": {
    "test": "test"
  }
}
